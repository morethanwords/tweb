{
  "name": "tweb",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "start": "vite",
    "start-in-docker": "vite --host",
    "serve": "pnpm run build; node server.js",
    "build": "pnpm run generate-changelog && vite build",
    "test": "vitest",
    "whybundled": "pnpm run profile && whybundled stats.json",
    "generate-mtproto-types": "node ./src/scripts/generate_mtproto_types.js src/",
    "generate-changelog": "node ./src/scripts/generate_changelog.js",
    "generate-icons": "node ./src/scripts/icomoon/icomoon_generate.js",
    "change-version": "node ./src/scripts/change_version.js",
    "apply-new-lang": "node ./src/scripts/apply_new_lang.js",
    "watch-lang": "node watch-lang.js",
    "lint": "npx eslint \"src/**/**.ts\"",
    "build:solid": "node ./src/scripts/build_solid.js",
    "format-lang": "node ./src/scripts/format_lang.js",
    "electron": "pnpm run build && electron electron/main.js",
    "electron:run": "electron electron/main.js",
    "electron:dev": "TWEB_DEV_URL=http://localhost:8080 electron electron/main.js",
    "electron:pack": "pnpm run build && electron-builder",
    "electron:smoke": "node electron/test/bridgeSmoke.js"
  },
  "author": "",
  "license": "GPL-3.0-only",
  "main": "electron/main.js",
  "dependencies": {
    "ws": "^8.20.0"
  },
  "build": {
    "appId": "org.telegram.tweb",
    "productName": "Telegram Web K",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "public/assets/**/*",
      "public/changelogs/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "protocols": [
      {
        "name": "Telegram Link",
        "schemes": ["tg"]
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.social-networking",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    }
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-typescript": "^7.23.3",
    "@cryptography/aes": "^0.1.1",
    "@cryptography/sha1": "^0.2.0",
    "@cryptography/sha256": "^0.2.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.0",
    "@peculiar/webcrypto": "^1.4.3",
    "@solid-primitives/refs": "^1.0.5",
    "@solid-primitives/transition-group": "^1.0.3",
    "@types/aes-js": "^3.1.4",
    "@types/chrome": "0.0.183",
    "@types/dom-webcodecs": "^0.1.13",
    "@types/express": "^5.0.6",
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/prismjs": "^1.26.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "aes-js": "^3.1.2",
    "autoprefixer": "^10.4.16",
    "big-integer": "^1.6.52",
    "browserslist": "^4.22.2",
    "compression": "^1.7.4",
    "csstype": "^3.1.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "express": "^5.2.1",
    "fake-indexeddb": "^6.2.5",
    "fast-png": "^6.2.0",
    "fflate": "^0.8.2",
    "globals": "^17.4.0",
    "hls.js": "^1.5.18",
    "http-proxy": "^1.18.1",
    "js-md5": "^0.8.3",
    "jsdom": "^22.1.0",
    "libsodium-wrappers": "^0.8.4",
    "mime": "^3.0.0",
    "mp4-muxer": "^5.1.3",
    "node-ssh": "^13.1.0",
    "prismjs": "^1.29.0",
    "qr-code-styling": "^1.5.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "sass": "^1.98.0",
    "tinyld": "^1.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-handlebars": "^2.0.0",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.0"
  },
  "packageManager": "pnpm@9.15.3+sha512.1f79bc245a66eb0b07c5d4d83131240774642caaa86ef7d0434ab47c0d16f66b04e21e0c086eb61e62c77efc4d7f7ec071afad3796af64892fae66509173893a"
}
